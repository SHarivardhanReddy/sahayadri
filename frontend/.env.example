# Frontend Environment Variables Template
# Copy this file to .env.production and update VITE_API_URL for your platform

# Backend API URL - Change this based on your deployment platform
VITE_API_URL=https://sahayadri-production.up.railway.app

## Platform Examples:

# Railway
# VITE_API_URL=https://sahayadri-production.up.railway.app

# Vercel/Netlify
# VITE_API_URL=https://your-backend-domain.com

# AWS/Heroku/Custom Server
# VITE_API_URL=https://api.yourdomain.com

# Local Development
# VITE_API_URL=http://localhost:5000

# Docker Compose
# VITE_API_URL=http://backend:5000
