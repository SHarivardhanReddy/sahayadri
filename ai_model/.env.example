# Flask Environment Configuration
# Set to 'production' for production deployment, 'development' for development
FLASK_ENV=production

# Flask Debug Mode (set to false in production)
FLASK_DEBUG=false

# Server Configuration
# In development, use 127.0.0.1; in production, use 0.0.0.0 to listen on all interfaces
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# Model Configuration
# Path to the trained model file (relative to the ai_model directory)
MODEL_PATH=fitness_model.joblib
FEATURES_PATH=model_features.json

# CORS Configuration
# Comma-separated list of allowed origins for cross-origin requests
ALLOWED_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO

# Production Deployment
# For Gunicorn: gunicorn --bind 0.0.0.0:5001 --workers 4 wsgi:app
WORKERS=4
TIMEOUT=60

