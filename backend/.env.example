# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ===== DATABASE =====
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dhrlfitness

# ===== SERVER =====
PORT=5000

# ===== GMAIL API (Email Service) =====
# Get these from: https://console.cloud.google.com
# Full setup guide: See GMAIL_API_SETUP.md

GMAIL_USER=your-email@gmail.com
CLIENT_ID=your-client-id-here.apps.googleusercontent.com
CLIENT_SECRET=your-client-secret-here
REFRESH_TOKEN=your-refresh-token-here

# ===== AI MODEL SERVER =====
# (Optional - if running AI server on different port)
AI_SERVER_URL=http://localhost:5001

# ===== NODE ENVIRONMENT =====
# Set to 'development' or 'production'
NODE_ENV=development
