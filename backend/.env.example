# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ===== DATABASE =====
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dhrlfitness

# ===== EMAIL CONFIGURATION (Gmail OAuth2) =====
# Get these from: https://console.cloud.google.com
GMAIL_USER=your-email@gmail.com
CLIENT_ID=xxxxx.apps.googleusercontent.com
CLIENT_SECRET=xxxxx
REFRESH_TOKEN=xxxxx

# ===== SERVER =====
PORT=5000
NODE_ENV=production

# ===== AI MODEL SERVER =====
# URL of the deployed AI server
# Local development: http://localhost:7860
# Railway/Production: https://your-ai-server-url.railway.app
AI_SERVER_URL=http://localhost:7860
